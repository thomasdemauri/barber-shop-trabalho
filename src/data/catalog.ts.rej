+// ‘Ų«‘Ų« Calendar Data (May 2026) ‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«‘Ų«
+// May 1, 2026 = Friday (dow=5)
+export type CalDay = {
+  d: number;
+  dow: number;
+  isWeekend: boolean;
+  isPast: boolean;
+  isToday: boolean;
+  available: boolean;
+} | null;
+
+export const CAL_DAYS: CalDay[] = (() => {
+  const arr: CalDay[] = Array(5).fill(null); // 5 empty slots before day 1 (Fri)
+  for (let d = 1; d <= 31; d++) {
+    const dow = (5 + d - 1) % 7;
+    arr.push({
+      d,
+      dow,
+      isWeekend: dow === 0 || dow === 6,
+      isPast: d < 12,
+      isToday: d === 12,
+      available: d > 12 && dow !== 0 && dow !== 6,
+    });
+  }
+  return arr;
+})();
+
+export const DOW_NAMES = ['Dom','Seg','Ter','Qua','Qui','Sex','S+Ūb'];
+export const getDayLabel = (d: number) => DOW_NAMES[(5 + d - 1) % 7];
+
